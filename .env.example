# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Anthropic API (AI analysis)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# NextAuth.js v5 — generate with: openssl rand -base64 32
AUTH_SECRET=change-me-generate-a-real-secret
AUTH_URL=http://localhost:3456

# Stripe Billing (international cards)
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here
STRIPE_STUDENT_MONTHLY_PRICE_ID=price_your-price-id
STRIPE_ANNUAL_PRICE_ID=price_your-price-id

# PayFast (SA payments: EFT, SnapScan, cards)
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true

# App URL (public-facing)
NEXT_PUBLIC_APP_URL=http://localhost:3456
